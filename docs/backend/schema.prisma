generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            String                    @id @default(uuid())
  firstName                     String?                   @map("first_name")
  lastName                      String?                   @map("last_name")
  email                         String                    @unique
  password                      String
  role                          RoleEnum                  @default(ADMIN)
  isArchived                    Boolean                   @default(false) @map("is_archived")

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  stockMovements                StockMovement[]
  inventoryAudits               InventoryAudit[]
  sales                         Sale[]                    @relation("SaleCashier")
  voidedSales                   Sale[]                    @relation("SaleVoider")

  @@map("users")
}

enum RoleEnum {
  SUPER_ADMIN
  ADMIN
  USER
}

// Flat product category (e.g. "Beverages", "Electronics").
model Category {
  id                            String                    @id @default(uuid())
  name                          String                    @unique
  description                   String?
  isArchived                    Boolean                   @default(false) @map("is_archived")

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  products                      Product[]

  @@map("categories")
}

// Vendor a product is purchased from, so stock can be re-ordered when it runs out.
model Supplier {
  id                            String                    @id @default(uuid())
  name                          String
  contactName                   String?                   @map("contact_name")
  email                         String?
  phone                         String?
  address                       String?
  notes                         String?
  isArchived                    Boolean                   @default(false) @map("is_archived")

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  products                      Product[]
  stockMovements                StockMovement[]
  links                         SupplierLink[]

  @@map("suppliers")
}

// External re-order link for a supplier (Messenger, Shopee, etc.) so the client can buy again from the original channel.
model SupplierLink {
  id                            String                    @id @default(uuid())
  supplierId                    String                    @map("supplier_id")
  platform                      SupplierPlatform
  url                           String
  label                         String?
  isArchived                    Boolean                   @default(false) @map("is_archived")

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  supplier                      Supplier                  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, platform])
  @@index([supplierId])
  @@map("supplier_links")
}

// Flat physical location (e.g. "Warehouse A", "Front Shelf") for auditing where stock lives.
model Location {
  id                            String                    @id @default(uuid())
  name                          String
  code                          String?                   @unique
  description                   String?
  isArchived                    Boolean                   @default(false) @map("is_archived")

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  products                      Product[]
  productUnits                  ProductUnit[]
  stockMovements                StockMovement[]
  inventoryAudits               InventoryAudit[]

  @@map("locations")
}

// Core SKU / catalog item. Fast-moving goods are tracked entirely here via quantityOnHand.
model Product {
  id                            String                    @id @default(uuid())
  name                          String
  description                   String?
  sku                           String                    @unique
  barcode                       String?                   @unique
  brand                         String?
  costPrice                     Decimal                   @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice                  Decimal                   @default(0) @map("selling_price") @db.Decimal(12, 2)
  quantityOnHand                Int                       @default(0) @map("quantity_on_hand")
  reorderPoint                  Int?                      @map("reorder_point")
  isSerialized                  Boolean                   @default(false) @map("is_serialized")
  isArchived                    Boolean                   @default(false) @map("is_archived")

  categoryId                    String                    @map("category_id")
  category                      Category                  @relation(fields: [categoryId], references: [id])

  supplierId                    String?                   @map("supplier_id")
  supplier                      Supplier?                 @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  locationId                    String?                   @map("location_id")
  location                      Location?                 @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  units                         ProductUnit[]
  stockMovements                StockMovement[]
  saleItems                     SaleItem[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([locationId])
  @@map("products")
}

// Individual physical unit of a serialized product. The rfidTag field is where RFID/EPC lives later.
model ProductUnit {
  id                            String                    @id @default(uuid())
  assetTag                      String?                   @unique @map("asset_tag")
  serialNumber                  String?                   @unique @map("serial_number")
  rfidTag                       String?                   @unique @map("rfid_tag")
  status                        ProductUnitStatus         @default(IN_STOCK)

  productId                     String                    @map("product_id")
  product                       Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  locationId                    String?                   @map("location_id")
  location                      Location?                 @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  stockMovements                StockMovement[]
  inventoryAuditScans           InventoryAuditScan[]
  saleItems                     SaleItem[]

  @@index([productId])
  @@index([locationId])
  @@map("product_units")
}

// Append-only audit ledger of every stock change. quantityAfter is a snapshot for trustworthy counts.
model StockMovement {
  id                            String                    @id @default(uuid())
  type                          StockMovementType
  quantityChange                Int                       @map("quantity_change")
  quantityAfter                 Int                       @map("quantity_after")
  note                          String?

  productId                     String                    @map("product_id")
  product                       Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  productUnitId                 String?                   @map("product_unit_id")
  productUnit                   ProductUnit?              @relation(fields: [productUnitId], references: [id], onDelete: SetNull)

  locationId                    String?                   @map("location_id")
  location                      Location?                 @relation(fields: [locationId], references: [id], onDelete: SetNull)

  supplierId                    String?                   @map("supplier_id")
  supplier                      Supplier?                 @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  userId                        String                    @map("user_id")
  user                          User                      @relation(fields: [userId], references: [id])

  saleId                        String?                   @map("sale_id")
  sale                          Sale?                     @relation(fields: [saleId], references: [id], onDelete: SetNull)

  saleItemId                    String?                   @map("sale_item_id")
  saleItem                      SaleItem?                 @relation(fields: [saleItemId], references: [id], onDelete: SetNull)

  createdAt                     DateTime                  @default(now()) @map("created_at")

  @@index([productId])
  @@index([productUnitId])
  @@index([supplierId])
  @@index([userId])
  @@index([saleId])
  @@index([saleItemId])
  @@map("stock_movements")
}

model Sale {
  id                            String                    @id @default(uuid())
  receiptNo                     String                    @unique @map("receipt_no")
  status                        SaleStatus                @default(COMPLETED)
  subtotal                      Decimal                   @db.Decimal(12, 2)
  total                         Decimal                   @db.Decimal(12, 2)
  amountTendered                Decimal                   @map("amount_tendered") @db.Decimal(12, 2)
  changeDue                     Decimal                   @map("change_due") @db.Decimal(12, 2)
  paymentMethod                 PaymentMethod             @map("payment_method")
  note                          String?
  receiptSnapshot               Json                      @map("receipt_snapshot")
  paidAt                        DateTime                  @default(now()) @map("paid_at")
  completedAt                   DateTime                  @default(now()) @map("completed_at")
  voidedAt                      DateTime?                 @map("voided_at")
  voidReason                    String?                   @map("void_reason")

  cashierId                     String                    @map("cashier_id")
  cashier                       User                      @relation("SaleCashier", fields: [cashierId], references: [id])

  voidedById                    String?                   @map("voided_by_id")
  voidedBy                      User?                     @relation("SaleVoider", fields: [voidedById], references: [id], onDelete: SetNull)

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  items                         SaleItem[]
  stockMovements                StockMovement[]

  @@index([cashierId])
  @@index([voidedById])
  @@index([completedAt])
  @@index([status])
  @@index([paymentMethod])
  @@map("sales")
}

model SaleItem {
  id                            String                    @id @default(uuid())
  quantity                      Int
  unitPrice                     Decimal                   @map("unit_price") @db.Decimal(12, 2)
  lineTotal                     Decimal                   @map("line_total") @db.Decimal(12, 2)
  productName                   String                    @map("product_name")
  productSku                    String                    @map("product_sku")
  productBarcode                String?                   @map("product_barcode")
  unitIdentifier                String?                   @map("unit_identifier")

  saleId                        String                    @map("sale_id")
  sale                          Sale                      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId                     String                    @map("product_id")
  product                       Product                   @relation(fields: [productId], references: [id])

  productUnitId                 String?                   @map("product_unit_id")
  productUnit                   ProductUnit?              @relation(fields: [productUnitId], references: [id], onDelete: SetNull)

  createdAt                     DateTime                  @default(now()) @map("created_at")

  stockMovements                StockMovement[]

  @@index([saleId])
  @@index([productId])
  @@index([productUnitId])
  @@map("sale_items")
}

model InventoryAudit {
  id                            String                    @id @default(uuid())
  auditNo                       String                    @unique @map("audit_no")
  status                        InventoryAuditStatus      @default(IN_PROGRESS)
  startedAt                     DateTime                  @default(now()) @map("started_at")
  completedAt                   DateTime?                 @map("completed_at")

  locationId                    String                    @map("location_id")
  location                      Location                  @relation(fields: [locationId], references: [id])

  userId                        String                    @map("user_id")
  user                          User                      @relation(fields: [userId], references: [id])

  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  scans                         InventoryAuditScan[]

  @@index([locationId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("inventory_audits")
}

model InventoryAuditScan {
  id                            String                    @id @default(uuid())
  scanValue                     String                    @map("scan_value")
  scanMode                      InventoryAuditScanMode    @default(RFID) @map("scan_mode")

  auditId                       String                    @map("audit_id")
  audit                         InventoryAudit            @relation(fields: [auditId], references: [id], onDelete: Cascade)

  productUnitId                 String?                   @map("product_unit_id")
  productUnit                   ProductUnit?              @relation(fields: [productUnitId], references: [id], onDelete: SetNull)
  
  result                        InventoryAuditScanResult  @default(UNKNOWN_TAG)
  scannedAt                     DateTime                  @default(now()) @map("scanned_at")

  @@index([auditId])
  @@index([scanValue])
  @@index([productUnitId])
  @@unique([auditId, scanValue])
  @@map("inventory_audit_scans")
}

enum ProductUnitStatus {
  IN_STOCK
  RESERVED
  SOLD
  DAMAGED
  RETURNED
  LOST
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  TRANSFER
  RETURN
  INITIAL
}

enum SupplierPlatform {
  MESSENGER
  VIBER
  SHOPEE
  LAZADA
  FACEBOOK
  WEBSITE
  OTHER
}

enum InventoryAuditStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InventoryAuditScanResult {
  MATCHED
  MISPLACED
  UNKNOWN_TAG
}

enum InventoryAuditScanMode {
  RFID
  BARCODE
  MANUAL
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  GCASH
  MAYA
  BANK_TRANSFER
  OTHER
}
